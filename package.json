{
  "name": "course-modern-agents",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "make:express": "node make-express.js",
    "dev:backend-api": "turbo dev --filter=backend-api",
    "dev:fe-web": "turbo dev --filter=fe-web",
    "dev:electron": "turbo dev --filter=desktop-electron",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{js,ts,tsx,md,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,md,json,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.2.3",
    "typescript": "5.5.4"
  },
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "inquirer": "^12.0.1"
  }
}
